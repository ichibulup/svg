{
  "name": "svg",
  "version": "0.1.2",
  "type": "module",
  "private": true,
  "scripts": {
    "pull": "pnpm install",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
